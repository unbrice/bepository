# bepository configuration
# Installed by `bepository install-service` to /etc/bepository/env (mode 600).
# Fill in the required values, then: systemctl start bepository

# --- Required ---

# Storage backend URI. Put non-secret config (region, project, endpoint) here.
# Local volume:  file:///var/lib/bepository/store   (writable under the service's StateDirectory)
# Amazon S3:     s3://my-bucket/syncthing?region=us-east-1
# S3-compatible: s3://my-bucket/syncthing?region=auto&endpoint=https://minio.example.com
# Google GCS:    gs://my-bucket/syncthing?project=my-gcp-project
#
# Note: a local file:// path outside /var/lib/bepository needs a ReadWritePaths=
# drop-in (the unit runs with ProtectSystem=strict). See INSTALL.md.
BEPOSITORY_STORAGE_URI=file:///var/lib/bepository/store

# Device ID of the Syncthing peer that will connect to this bridge.
# Obtain it from the peer's Syncthing UI: Actions → Show ID
BEPOSITORY_MASTER_DEVICE_ID=XXXXXXX-XXXXXXX-XXXXXXX-XXXXXXX-XXXXXXX-XXXXXXX-XXXXXXX-XXXXXXX

# Address for bepository to listen on for BEP connections.
BEPOSITORY_LISTEN=127.0.0.1:22001

# --- Optional ---

# Path for the Foyer hybrid block cache. WARNING: do NOT point this at the
# service's CacheDirectory (/var/cache/bepository) — the on-disk cache has no
# cross-process lock, so a concurrent ad-hoc command (e.g. get-id, fsck) and
# the running daemon would corrupt each other's index. Left unset, ad-hoc
# commands fall through to a per-user XDG cache dir (cold reads, no sharing).
# BEPOSITORY_CACHE_DIRECTORY=

# Disable the on-disk block cache (e.g. when the object store is a local NAS).
# BEPOSITORY_NO_CACHE=1

# Distributed-lock tuning.
# BEPOSITORY_PRIORITY=100   # higher priority wins when two instances compete for the same store
# BEPOSITORY_LEASE=180      # lock lease in seconds (minimum 180)

# Password for the WebDAV checkpoint browser (bepository checkpoint serve).
# BEPOSITORY_DAV_PASSWORD=changeme

# --- Cloud storage credentials (leave blank for local file:// storage) ---
#
# AWS
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
#
# GCS — path to a service-account JSON key. Drop the file at
# /etc/bepository/sa-key.json (chmod 600). The service runs under
# DynamicUser=yes, so it cannot read a root-owned file by path: hand it to
# systemd via `systemctl edit bepository` ->
#   [Service]
#   LoadCredential=sa-key.json:/etc/bepository/sa-key.json
# then point the env var at the credential path systemd exposes:
# GOOGLE_APPLICATION_CREDENTIALS=/run/credentials/bepository.service/sa-key.json
#
# GCS — short-lived bearer token (alternative to a key file).
# CLOUDSDK_AUTH_ACCESS_TOKEN=
