# bepository deployment configuration
# Copy to .env and fill in the required values.

# --- Required ---

# Storage backend URI. Put non-secret config (region, project, endpoint) here.
# Local volume:  file:///data
# Amazon S3:     s3://my-bucket/syncthing?region=us-east-1
# S3-compatible: s3://my-bucket/syncthing?region=auto&endpoint=https://minio.example.com
# Google GCS:    gs://my-bucket/syncthing?project=my-gcp-project
BEPOSITORY_STORAGE_URI=file:///data

# Device ID of the Syncthing peer that will connect to this bridge.
# Obtain it from the peer's Syncthing UI: Actions → Show ID
BEPOSITORY_MASTER_DEVICE_ID=XXXXXXX-XXXXXXX-XXXXXXX-XXXXXXX-XXXXXXX-XXXXXXX-XXXXXXX-XXXXXXX

# Host port to expose the BEP listener on.
BEPOSITORY_PORT=22001

# --- Optional ---

# Path for the Foyer hybrid block cache (default: /var/cache/bepository in
# containers; XDG cache dir otherwise).
# BEPOSITORY_CACHE_DIRECTORY=/var/cache/bepository

# Disable the on-disk block cache (e.g. when the object store is a local NAS).
# BEPOSITORY_NO_CACHE=1

# Distributed-lock tuning.
# BEPOSITORY_PRIORITY=100   # higher priority wins when two instances compete for the same store
# BEPOSITORY_LEASE=180      # lock lease in seconds (minimum 180)

# Password for the WebDAV checkpoint browser (bepository checkpoint serve).
# BEPOSITORY_DAV_PASSWORD=changeme

# --- Cloud storage credentials (leave blank for local file:// storage) ---
#
# AWS
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
#
# GCS — path to a service-account JSON key. Drop the file at
# /etc/bepository/sa-key.json (chmod 600); the Quadlet/Compose unit mounts
# /etc/bepository read-only into the container.
# GOOGLE_APPLICATION_CREDENTIALS=/etc/bepository/sa-key.json
#
# GCS — short-lived bearer token (alternative to a key file).
# CLOUDSDK_AUTH_ACCESS_TOKEN=
