# bepository deployment configuration
# Copy to .env and fill in the required values.

# --- Required ---

# Storage backend URI. Put non-secret config (region, project, endpoint) here.
# Local volume:  file:///data
# Amazon S3:     s3://my-bucket/syncthing?region=us-east-1
# S3-compatible: s3://my-bucket/syncthing?region=auto&endpoint=https://minio.example.com
# Google GCS:    gs://my-bucket/syncthing?project=my-gcp-project
STORAGE_URI=file:///data

# Device ID of the Syncthing peer that will connect to this bridge.
# Obtain it from the peer's Syncthing UI: Actions → Show ID
MASTER_DEVICE_ID=XXXXXXX-XXXXXXX-XXXXXXX-XXXXXXX-XXXXXXX-XXXXXXX-XXXXXXX-XXXXXXX

# --- Optional ---

# Host port to expose the BEP listener on (default: 22001).
LISTEN_PORT=22001

# Path for the Foyer hybrid block cache (optional, default: /var/cache/bepository).
# CACHE_DIRECTORY=/var/cache/bepository

# Distributed-lock tuning (optional).
# PRIORITY=100   # higher priority wins when two instances compete for the same store
# LEASE=180      # lock lease in seconds (minimum 180)

# Extra CLI args appended to the `serve` command (optional).
# Example: disable the on-disk block cache when the object store is local.
# EXTRA_ARGS=--no-cache

# --- Cloud storage credentials (leave blank for local file:// storage) ---
#
# AWS
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
#
# GCS — service-account key as JSON content.
#   Wrap in single quotes to handle newlines: GOOGLE_SERVICE_ACCOUNT_KEY='{"type":"service_account",...}'
# GOOGLE_SERVICE_ACCOUNT_KEY=
# GCS — short-lived bearer token (from `gcloud auth print-access-token`).
# CLOUDSDK_AUTH_ACCESS_TOKEN=
# GCS — path to a service-account key file on disk.
# GOOGLE_APPLICATION_CREDENTIALS=
